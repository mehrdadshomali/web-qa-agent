# Anahtarı console.anthropic.com'dan (API Keys) alın ve bu dosyayı .env olarak
# kopyalayıp değeri yapıştırın. .env git'e dahil edilmez (.gitignore).
ANTHROPIC_API_KEY=sk-ant-...

# --login ile auth arkasındaki sayfaları salt-okunur taramak için kimlik bilgileri.
# Rol, runner.py --role <rol> ile seçilir; her rol QA_<ROL>_EMAIL/PASSWORD okur.
# Değerler, hedef uygulamada seed'lenen atılabilir QA test hesaplarıyla eşleşmeli
# (QaTestUsersSeeder). .env git'e dahil edilmez; gerçek şifreyi buraya değil .env'e koyun.
#
# youth: geriye dönük uyumluluk için QA_LOGIN_* de kabul edilir (aşağıdaki gibi).
QA_LOGIN_EMAIL=test-youth@qa.local
QA_LOGIN_PASSWORD=
# youth'u açıkça vermek isterseniz (QA_LOGIN_* ile eşdeğer):
# QA_YOUTH_EMAIL=test-youth@qa.local
# QA_YOUTH_PASSWORD=
# brand rolü (runner.py --login --role brand):
QA_BRAND_EMAIL=test-brand@qa.local
QA_BRAND_PASSWORD=

# Faz 4: Telegram botu (telegram_bot.py). Botu @BotFather'dan oluşturun, token'ı
# buraya koyun. TELEGRAM_CHAT_ID'yi get_chat_id.py ile öğrenin (bota /start yazıp
# çalıştırın). Bot yalnızca bu chat_id'den gelen mesajlara cevap verir.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Faz 5(a): 500 hataları için kod-destekli teşhis (code_context.py). OPSİYONEL —
# tanımlıysa, ilgili kaynak koddan (SALT-OKUMA) parça toplanır. Hedef uygulamanın
# kök dizini (app/ database/ routes/ içeren; ör. bir Laravel projesinin kökü).
# Boş bırakılırsa kod okuma atlanır (araç yine çalışır).
TARGET_REPO_PATH=
