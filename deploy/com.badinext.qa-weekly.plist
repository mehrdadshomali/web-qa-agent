<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  web-qa-agent — haftalık QA taraması (launchd LaunchAgent).

  Her Pazartesi 09:00'da weekly_run.py'yi (venv python ile) çalıştırır.

  Kurulum:
    cp deploy/com.badinext.qa-weekly.plist ~/Library/LaunchAgents/
    launchctl load -w ~/Library/LaunchAgents/com.badinext.qa-weekly.plist

  Elle test (hemen bir kez çalıştır):
    launchctl start com.badinext.qa-weekly
    # veya modern:
    launchctl kickstart -k gui/$(id -u)/com.badinext.qa-weekly

  Durdurma/kaldırma:
    launchctl unload -w ~/Library/LaunchAgents/com.badinext.qa-weekly.plist

  NOT: Aşağıdaki yollar bu makineye özgüdür (/Users/mehrdadshomali/...).
       Farklı bir kullanıcı/dizinde kullanacaksan hepsini güncelle.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.badinext.qa-weekly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/mehrdadshomali/web-qa-agent/venv/bin/python</string>
        <string>/Users/mehrdadshomali/web-qa-agent/weekly_run.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/mehrdadshomali/web-qa-agent</string>

    <!-- Her Pazartesi 09:00 (Weekday: 0/7=Pazar, 1=Pazartesi ... 6=Cumartesi) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- launchd job'un çıktısı (weekly_run zaten logs/weekly.log'a ayrıca yazar) -->
    <key>StandardOutPath</key>
    <string>/Users/mehrdadshomali/web-qa-agent/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mehrdadshomali/web-qa-agent/logs/launchd.err.log</string>

    <!-- Yüklerken hemen çalışmasın; sadece takvim tetiklesin (elle test edeceğiz). -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
